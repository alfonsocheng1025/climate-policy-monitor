# Ingest layer (Python) connects with DATABASE_URL (note: web uses POSTGRES_URL).
# Use the Supabase **Session Pooler** string (IPv4): aws-0-<region>.pooler.supabase.com:5432
# Do NOT use the "Direct connection" (db.<ref>.supabase.co) — it is IPv6-only on the free
# tier and fails on most IPv4 / proxied networks (incl. many China networks).
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Optional source overrides (sensible defaults are baked into the fetch scripts):
# CAPMF_START=2000
# CAPMF_END=2023
# CW_MAX_PAGES=40
# CPR_MAX_ROWS=20000
# WB_CARBON_URL=https://carbonpricingdashboard.worldbank.org/sites/default/files/carbon-pricing-dashboard-data/data_05_2026.xlsx
# NETZERO_URL=https://ourworldindata.org/grapher/net-zero-targets.csv?v=1&csvType=full&useColumnShortNames=true
