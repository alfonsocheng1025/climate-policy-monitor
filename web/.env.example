# Web layer (Next.js) uses postgres.js, which reads POSTGRES_URL.
# MUST be the Supabase **Transaction Pooler** string (IPv4), e.g.:
#   postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Tells: username is "postgres.<ref>" and host contains "pooler.supabase.com".
# Do NOT use the Direct connection (postgres@db.<ref>.supabase.co:5432) — it is
# IPv6-only and @-style direct strings are rejected.
POSTGRES_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
